package com.E_commerce.Ropa.de.Segunda.Mano.Cliente;

import org.springframework.cloud.openfeign.FeignClient;
import org.springframework.web.bind.annotation.PathVariable;
import org.springframework.web.bind.annotation.PutMapping;
import org.springframework.web.bind.annotation.RequestParam;

@FeignClient(name = "ms-stock", url = "localhost:8087") 
public interface StockClient {
    
    @PutMapping("/api/stock/descontar/{id}")
    void descontarStock(@PathVariable("id") Long prendaId, @RequestParam("cantidad") Integer cantidad);
}